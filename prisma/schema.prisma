generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Usuario {
  id          String       @id @default(uuid())
  email       String       @unique
  senha_hash  String
  perfil      String       @default("ATENDENTE")
  funcionario Funcionario?
  criadoEm   DateTime     @default(now())
}

model Cliente {
  id       String    @id @default(uuid())
  nome     String
  email    String    @unique
  telefone String?
  tipo     String
  cpf      String?   @unique
  cnpj     String?   @unique
  endereco String?
  criadoEm DateTime  @default(now())
  veiculos Veiculo[]
}

model Veiculo {
  id           String        @id @default(uuid())
  placa        String        @unique
  marca        String
  modelo       String
  ano          Int
  cor          String?
  clienteId    String
  cliente      Cliente       @relation(fields: [clienteId], references: [id])
  agendamentos Agendamento[]
  criadoEm    DateTime      @default(now())
}

model Funcionario {
  id            String        @id @default(uuid())
  nome          String
  cargo         String
  especialidade String?
  salario       Decimal
  telefone      String?
  data_admissao DateTime?
  ativo         Boolean       @default(true)
  usuarioId     String?       @unique
  usuario       Usuario?      @relation(fields: [usuarioId], references: [id])
  itensServico  ItemServico[]
  criadoEm     DateTime      @default(now())
}

model TipoServico {
  id             String        @id @default(uuid())
  nome           String        @unique
  descricao      String?
  preco_base     Decimal
  tempo_estimado Int
  itensServico   ItemServico[]
  criadoEm      DateTime      @default(now())
}

model Peca {
  id                String     @id @default(uuid())
  nome              String
  descricao         String?
  preco_unitario    Decimal
  quantidade        Int        @default(0)
  quantidade_minima Int        @default(0)
  fornecedor        String?
  itensPeca         ItemPeca[]
  criadoEm         DateTime   @default(now())
}

model Agendamento {
  id          String        @id @default(uuid())
  veiculoId   String
  veiculo     Veiculo       @relation(fields: [veiculoId], references: [id])
  status      String        @default("AGENDADO")
  km_entrada  Int
  km_saida    Int?
  aberturaEm  DateTime      @default(now())
  conclusaoEm DateTime?
  observacoes String?
  itensServico ItemServico[]
  itensPeca    ItemPeca[]
  pagamento    Pagamento?
  avaliacao    Avaliacao?
  criadoEm    DateTime      @default(now())
}

model ItemServico {
  id             String      @id @default(uuid())
  agendamentoId  String
  agendamento    Agendamento @relation(fields: [agendamentoId], references: [id])
  tipoServicoId  String
  tipoServico    TipoServico @relation(fields: [tipoServicoId], references: [id])
  funcionarioId  String
  funcionario    Funcionario @relation(fields: [funcionarioId], references: [id])
  quantidade     Int         @default(1)
  preco_unitario Decimal
  desconto       Decimal     @default(0)
  criadoEm      DateTime    @default(now())
}

model ItemPeca {
  id             String      @id @default(uuid())
  agendamentoId  String
  agendamento    Agendamento @relation(fields: [agendamentoId], references: [id])
  pecaId         String
  peca           Peca        @relation(fields: [pecaId], references: [id])
  quantidade     Int         @default(1)
  preco_unitario Decimal
  desconto       Decimal     @default(0)
  criadoEm      DateTime    @default(now())
}

model Pagamento {
  id              String      @id @default(uuid())
  agendamentoId   String      @unique
  agendamento     Agendamento @relation(fields: [agendamentoId], references: [id])
  valor_total     Decimal
  forma_pagamento String
  parcelas        Int         @default(1)
  status          String      @default("PENDENTE")
  criadoEm       DateTime    @default(now())
}

model Avaliacao {
  id            String      @id @default(uuid())
  agendamentoId String      @unique
  agendamento   Agendamento @relation(fields: [agendamentoId], references: [id])
  nota          Int
  comentario    String?
  criadoEm     DateTime    @default(now())
}
